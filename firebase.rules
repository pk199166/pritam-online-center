rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /customers/{uid} {
      allow read, write: if true;
    }
    match /customers/{uid}/history/{historyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'pk199166@gmail.com';
    }
    match /notifications/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'pk199166@gmail.com';
    }
    match /finance/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'pk199166@gmail.com';
    }
    match /appointments/{docId} {
      allow read, write: if request.auth != null;
    }
    match /system/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'pk199166@gmail.com';
    }
  }
}